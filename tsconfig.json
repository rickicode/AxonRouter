{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "types": [
      "node"
    ],
    "allowJs": false,
    "checkJs": false,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "ignoreDeprecations": "6.0",
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "open-sse": [
        "./open-sse"
      ],
      "open-sse/*": [
        "./open-sse/*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "moduleDetection": "force",
    "noPropertyAccessFromIndexSignature": false,
    "noCheck": false,
    "noUncheckedSideEffectImports": false
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "packages/tunnel",
    "tests/node_modules",
    "tests/tmp",
    "tests/**/*.test.ts",
    "tests/**/*.test.tsx",
    "tests/setup.ts",
    "tests/vitest.config.ts",
    "tests/autopilot-plugin.test.ts",
    "vitest.config.ts"
  ]
}
