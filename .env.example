# AxonRouter - No configuration needed
# All settings are managed via the dashboard at http://localhost:12711/dashboard
# Data is stored in ~/.axonrouter
#
# Just run: npx axonrouter
# Or with custom port: PORT=3000 axonrouter

# --- Optional environment variables ---

# Dashboard password (bcrypt-hashed on first start).
# If unset, defaults to "12345677". Change via dashboard Settings after first login.
# AXONROUTER_PASSWORD=your-secret-password

# Custom port (default: 12711)
# PORT=3000

# Custom hostname (default: 127.0.0.1)
# HOSTNAME=0.0.0.0
