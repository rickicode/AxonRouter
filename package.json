{
  "name": "axonrouter",
  "version": "0.2.0",
  "description": "Route AI coding tools across providers.",
  "private": false,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "files": [
    "bin/axonrouter.js",
    ".next/standalone/",
    ".next/static/",
    "public/",
    "open-sse/",
    "src/",
    "!src/node_modules/",
    "!src/package.json",
    "!src/package-lock.json",
    "scripts/start.js",
    "scripts/service.js",
    "scripts/ensure-middleware-manifest.js",
    "scripts/mcp-stdio.js",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "axonrouter": "bin/axonrouter.js"
  },
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --turbopack --port 12712",
    "build": "NODE_ENV=production next build --turbopack && node ./scripts/ensure-middleware-manifest.js",
    "start": "NODE_ENV=production node ./scripts/start.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --reporter=verbose --root tests",
    "publish": "bash ./scripts/publish.sh",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/pacer": "^0.21.1",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.24",
    "@xyflow/react": "^12.10.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "confbox": "^0.2.4",
    "got-scraping": "^4.2.1",
    "lowdb": "^7.0.1",
    "lucide-react": "^1.14.0",
    "marked": "^18.0.1",
    "monaco-editor": "^0.55.1",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "node-forge": "^1.3.3",
    "node-gyp": "^12.1.0",
    "open": "^11.0.0",
    "ora": "^9.1.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.57.2",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/semantic-conventions": "^1.30.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.2",
    "paseto": "^3.1.4",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.19.0",
    "undici": "^7.19.2",
    "uuid": "^13.0.2",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@tanstack/react-query-devtools": "^5.100.10",
    "@types/react": "19.2.14",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "postcss": "^8.5.10",
    "shadcn": "^4.7.0",
    "tailwindcss": "^4",
    "typescript": "^6.0.3",
    "vitest": "^4.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rickicode/AxonRouter.git"
  },
  "keywords": [
    "ai-router",
    "llm-proxy",
    "openai",
    "claude",
    "gemini",
    "smart-fallback",
    "rate-limiting"
  ],
  "author": "rickicode",
  "license": "MIT",
  "engines": {
    "node": ">=22.6.0"
  },
  "homepage": "https://github.com/rickicode/AxonRouter#readme",
  "publishConfig": {
    "access": "public"
  },
  "overrides": {
    "dompurify": "^3.4.0"
  }
}
